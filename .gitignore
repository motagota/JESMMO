# Rust
/target/
/rust_server/target/
**/*.rs.bk

# terrain-bake's per-stage cache (regenerable; the checked-in artifact itself,
# e.g. /artifacts/world_v1/manifest.toml + tiles/, is not gitignored)
**/.cache/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Server logs / runtime output
server/*_out.txt
server/*_err.txt
*.log

# SQLite dev/test databases (created at runtime; never committed)
*.db
*.db-wal
*.db-shm

# OS / editor
.DS_Store
Thumbs.db
